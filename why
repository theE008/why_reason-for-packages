#!/bin/bash

# --- 1. Context Detection ---
# Determines if we are in a local project or global system mode.
IS_LOCAL=false
if [ -d "$PWD/reasons" ]; then
    # Local Mode: Use current directory's 'reasons' folder.
    # We do NOT manage git here; we assume the parent project handles it.
    BASE_DIR="$PWD/reasons"
    IS_LOCAL=true
else
    # Global Mode: Use the directory where the script lives.
    # We manage an internal hidden .git for system-wide auditing.
    BASE_DIR="$(dirname "$(readlink -f "$0")")"
fi

# --- 2. Configuration & Paths ---
HISTORY_DIR="$BASE_DIR/history"
MANIFEST="$BASE_DIR/manifest.db"
INSTALL_LOG="$BASE_DIR/install.bash"
CONF_FILE="$BASE_DIR/why.conf"

# Ensure directories exist
mkdir -p "$HISTORY_DIR"

# Global Mode setup: Initialize internal git if not present
if [ "$IS_LOCAL" = false ]; then
    if [ ! -d "$BASE_DIR/.git" ]; then
        cd "$BASE_DIR" && git init > /dev/null
    fi
fi

# --- 3. Parse Configuration (why.conf) ---
# Allows simplifying commands: e.g., 'install: cargo install'
CONF_INSTALL=""
CONF_UNINSTALL=""
CONF_ITERATE=""

if [ -f "$CONF_FILE" ]; then
    CONF_INSTALL=$(awk -F': +' '$1=="install"{print $2}' "$CONF_FILE")
    CONF_UNINSTALL=$(awk -F': +' '$1=="remove" || $1=="uninstall"{print $2}' "$CONF_FILE")
    CONF_ITERATE=$(awk -F': +' '$1=="iterate"{print $2}' "$CONF_FILE")
fi

# --- 4. Helper Functions ---
get_registry() {
    # Extracts the first word of the command (ignoring sudo)
    echo "$1" | sed 's/sudo //' | awk '{print $1}'
}

log_history() {
    local registry=$1
    local pkg=$2
    local status=$3
    local reason=$4
    local timestamp=$(date "+%Y-%m-%d %H:%M")
    echo "[$timestamp] $pkg: $status $reason" >> "$HISTORY_DIR/${registry}.db"
}

auto_commit() {
    if [ "$IS_LOCAL" = false ]; then
        cd "$BASE_DIR" || return
        git add . && git commit -m "$1" > /dev/null
    fi
}

print_header() {
    if [ "$IS_LOCAL" = true ]; then
        echo -e "\033[1;34m[why:local]\033[0m Operating in project workspace."
    fi
}

# --- 5. Command Logic ---

case "$1" in
    install|-S|add)
        print_header
        # Handle logic for config-based vs manual commands
        if [ -n "$CONF_INSTALL" ] && [ $# -eq 3 ]; then
            CMD="$CONF_INSTALL"
            PKGS="$2"
            REASON="$3"
        else
            CMD="$2"
            PKGS="$3"
            REASON="$4"
        fi

        if [[ -z "$CMD" || -z "$PKGS" || -z "$REASON" ]]; then
            echo "Usage (Manual): why install \"<command>\" \"<pkgs>\" \"<reason>\""
            echo "Usage (Config): why install \"<pkgs>\" \"<reason>\""
            exit 1
        fi

        REGISTRY=$(get_registry "$CMD")

        # Show previous history for the package if it exists
        for pkg in $PKGS; do
            if grep -q "$pkg" "$HISTORY_DIR/${REGISTRY}.db" 2>/dev/null; then
                echo -e "\nHistory for $pkg:"
                grep "$pkg" "$HISTORY_DIR/${REGISTRY}.db"
            fi
        done

        echo -e "\nExecuting: $CMD $PKGS..."
        eval "$CMD $PKGS"

        if [ $? -eq 0 ]; then
            for pkg in $PKGS; do
                log_history "$REGISTRY" "$pkg" "[INSTALLED]" "$REASON"
                echo "$REGISTRY|$pkg" >> "$MANIFEST"
            done
            echo "$CMD $PKGS # Reason: $REASON" >> "$INSTALL_LOG"
            sort -u -o "$MANIFEST" "$MANIFEST"
            
            auto_commit "Install ($REGISTRY): $PKGS - $REASON"
            echo "Successfully logged."
        else
            echo "Command failed. Nothing logged."
        fi
        ;;

    uninstall|-Rs|-R|remove)
        print_header
        if [ -n "$CONF_UNINSTALL" ] && [ $# -eq 3 ]; then
            CMD="$CONF_UNINSTALL"
            PKGS="$2"
            REASON="$3"
        else
            CMD="$2"
            PKGS="$3"
            REASON="$4"
        fi

        REGISTRY=$(get_registry "$CMD")

        eval "$CMD $PKGS"
        if [ $? -eq 0 ]; then
            for pkg in $PKGS; do
                log_history "$REGISTRY" "$pkg" "<REMOVED>" "$REASON"
                sed -i "/$REGISTRY|$pkg/d" "$MANIFEST" 2>/dev/null
                sed -i "/\b$pkg\b/d" "$INSTALL_LOG" 2>/dev/null
            done
            auto_commit "Uninstall ($REGISTRY): $PKGS - $REASON"
            echo "Removal logged."
        fi
        ;;

    reason|history|why)
        SEARCH=$2
        if [[ -z "$SEARCH" ]]; then
            echo "Usage: why reason <package_name>"
            exit 1
        fi
        echo "Searching history for: $SEARCH"
        grep -h --color=always "$SEARCH" "$HISTORY_DIR"/*.db 2>/dev/null || echo "No history found for '$SEARCH'."
        ;;

    iterate|audit)
        print_header
        if [ -n "$CONF_ITERATE" ] && [ $# -eq 2 ]; then
            LIST_CMD="$CONF_ITERATE"
            REGISTRY=$(get_registry "$LIST_CMD")
        else
            LIST_CMD="$2"
            REGISTRY="$3"
        fi

        if [[ -z "$LIST_CMD" || -z "$REGISTRY" ]]; then
            echo "Usage: why iterate \"<list command>\" <registry_name>"
            exit 1
        fi

        while read -r pkg; do
            pkg_clean=$(echo "$pkg" | awk '{print $1}')
            if ! grep -q "$REGISTRY|$pkg_clean" "$MANIFEST" 2>/dev/null; then
                echo -e "\n[UNKNOWN PACKAGE] $pkg_clean"
                read -p "Why is this installed? (Leave empty to skip): " reason < /dev/tty
                if [[ -n "$reason" ]]; then
                    log_history "$REGISTRY" "$pkg_clean" "[AUDITED]" "$reason"
                    echo "$REGISTRY|$pkg_clean" >> "$MANIFEST"
                    auto_commit "Audit ($REGISTRY): $pkg_clean"
                fi
            fi
        done < <(eval "$LIST_CMD")
        ;;

    status)
        echo "Environment: $([ "$IS_LOCAL" = true ] && echo "Local (reasons/)" || echo "Global")"
        echo "Database Path: $BASE_DIR"
        echo "Config Active: $([ -f "$CONF_FILE" ] && echo "Yes" || echo "No")"
        if [ -f "$CONF_FILE" ]; then
            echo "--- Config Defaults ---"
            cat "$CONF_FILE"
        fi
        ;;

    *)
        echo "Commands: install, uninstall, reason, iterate, status"
        exit 1
        ;;
esac
